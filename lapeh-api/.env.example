APP_NAME=Lapeh
APP_ENV=local
APP_KEY=base64:YOUR_APP_KEY
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_TIMEZONE=Asia/Dubai

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=lapeh
DB_USERNAME=root
DB_PASSWORD=your_mysql_password

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

REVERB_APP_ID=lapeh-app
REVERB_APP_KEY=lapeh-reverb-key
REVERB_APP_SECRET=lapeh-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@lapeh.app"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=me-south-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Phone OTP — no SMS provider yet. In local/testing/development the OTP is
# returned in the API response and this master code is also accepted.
MASTER_OTP=123456

# Firebase Cloud Messaging (HTTP v1). Download the service-account JSON from
# Firebase Console → Project Settings → Service accounts → Generate new private key.
# Store it OUTSIDE version control (the path below is git-ignored).
FIREBASE_CREDENTIALS=storage/app/firebase/service-account.json
FIREBASE_PROJECT_ID=lapeh-51e34

PAYMENT_GATEWAY=stripe
PAYMENT_KEY=
PAYMENT_SECRET=
# HMAC-SHA256 secret used to verify inbound gateway webhooks (X-Signature header)
PAYMENT_WEBHOOK_SECRET=

SMS_PROVIDER=log

VITE_APP_NAME="${APP_NAME}"
